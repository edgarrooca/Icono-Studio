{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "img": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "description", "category", "img"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Website configuration",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "contactEmail": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "Collection of projects"
    },
    "/settings/site": {
      "schema": { "$ref": "SiteSettings" },
      "description": "Global site settings"
    }
  }
}
